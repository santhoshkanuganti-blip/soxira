# Contact form recipients
CONTACT_NOTIFICATION_RECIPIENTS=info@soxira.com,info@soxirasolutions.com

# Display sender for outgoing mail
CONTACT_FROM_EMAIL=Soxira Contact <info@soxira.com>

# Preferred option for your Hostinger email account (info@soxira.com)
# Typical Hostinger defaults: host=smtp.hostinger.com, port=465, secure=true
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@soxira.com
SMTP_PASS=replace-with-your-hostinger-email-password

# Optional fallback provider if SMTP is not configured
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
